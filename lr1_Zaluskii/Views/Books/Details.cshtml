@model lr1_Zaluskii.Models.Book

@{
    ViewData["Title"] = "Деталі книги";
}

<h1>Деталі книги</h1>
<hr />

<dl class="row">
    <dt class="col-sm-3">Назва</dt>
    <dd class="col-sm-9">@Model.Title</dd>

    <dt class="col-sm-3">Автор</dt>
    <dd class="col-sm-9">@Model.Author</dd>

    <dt class="col-sm-3">ISBN</dt>
    <dd class="col-sm-9">@Model.ISBN</dd>

    <dt class="col-sm-3">Рік видання</dt>
    <dd class="col-sm-9">@Model.PublishedYear</dd>

    <dt class="col-sm-3">Кількість сторінок</dt>
    <dd class="col-sm-9">@Model.Pages</dd>

    <dt class="col-sm-3">Жанр</dt>
    <dd class="col-sm-9">@Model.Genre</dd>
</dl>

<h4 class="mt-4">Історія видач</h4>
@if (Model.BookIssues != null && Model.BookIssues.Any())
{
    <table class="table table-sm table-striped">
        <thead>
            <tr>
                <th>Читач</th>
                <th>Дата видачі</th>
                <th>Термін повернення</th>
                <th>Повернуто</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var issue in Model.BookIssues)
            {
                <tr>
                    <td>@issue.Reader?.FullName</td>
                    <td>@issue.IssueDate.ToShortDateString()</td>
                    <td>@issue.DueDate.ToShortDateString()</td>
                    <td>
                        @if (issue.IsReturned)
                        {
                            <span class="badge bg-success">Так (@issue.ReturnDate?.ToShortDateString())</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark">Ні</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="text-muted">Книга ще не видавалась.</p>
}

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Редагувати</a>
    <a asp-action="Index" class="btn btn-secondary">До списку</a>
</div>
