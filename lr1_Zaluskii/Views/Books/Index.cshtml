@model IEnumerable<lr1_Zaluskii.Models.Book>

@{
    ViewData["Title"] = "Книги";
}

<h1>Каталог книг</h1>
<p>
    <a asp-action="Create" class="btn btn-primary">+ Додати книгу</a>
</p>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Назва</th>
            <th>Автор</th>
            <th>ISBN</th>
            <th>Рік видання</th>
            <th>Сторінок</th>
            <th>Жанр</th>
            <th>Дії</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>@item.Author</td>
                <td>@item.ISBN</td>
                <td>@item.PublishedYear</td>
                <td>@item.Pages</td>
                <td>@item.Genre</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Деталі</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Редагувати</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Видалити</a>
                </td>
            </tr>
        }
    </tbody>
</table>
