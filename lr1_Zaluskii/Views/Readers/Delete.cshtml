@model lr1_Zaluskii.Models.Reader

@{
    ViewData["Title"] = "Видалити читача";
}

<h1>Видалити читача</h1>
<h3 class="text-danger">Ви впевнені, що хочете видалити цього читача?</h3>
<hr />

<dl class="row">
    <dt class="col-sm-3">Ім'я</dt>
    <dd class="col-sm-9">@Model.FirstName</dd>

    <dt class="col-sm-3">Прізвище</dt>
    <dd class="col-sm-9">@Model.LastName</dd>

    <dt class="col-sm-3">Email</dt>
    <dd class="col-sm-9">@Model.Email</dd>

    <dt class="col-sm-3">Телефон</dt>
    <dd class="col-sm-9">@Model.Phone</dd>

    <dt class="col-sm-3">Номер читацького квитка</dt>
    <dd class="col-sm-9">@Model.LibraryCardNumber</dd>

    <dt class="col-sm-3">Дата реєстрації</dt>
    <dd class="col-sm-9">@Model.DateRegistered.ToShortDateString()</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Видалити" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-secondary">Скасувати</a>
</form>
