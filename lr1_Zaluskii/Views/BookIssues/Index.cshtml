@model IEnumerable<lr1_Zaluskii.Models.BookIssue>

@{
    ViewData["Title"] = "Видача книг";
}

<h1>Журнал видачі книг</h1>
<p>
    <a asp-action="Create" class="btn btn-primary">+ Видати книгу</a>
</p>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Книга</th>
            <th>Читач</th>
            <th>Дата видачі</th>
            <th>Термін повернення</th>
            <th>Статус</th>
            <th>Дії</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Book?.Title</td>
                <td>@item.Reader?.FullName</td>
                <td>@item.IssueDate.ToShortDateString()</td>
                <td>@item.DueDate.ToShortDateString()</td>
                <td>
                    @if (item.IsReturned)
                    {
                        <span class="badge bg-success">Повернуто @item.ReturnDate?.ToShortDateString()</span>
                    }
                    else if (item.DueDate < DateTime.Now)
                    {
                        <span class="badge bg-danger">Прострочено</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">На руках</span>
                    }
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Деталі</a>
                    @if (!item.IsReturned)
                    {
                        <form asp-action="Return" asp-route-id="@item.Id" method="post" style="display:inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-success btn-sm">Повернути</button>
                        </form>
                    }
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Редагувати</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Видалити</a>
                </td>
            </tr>
        }
    </tbody>
</table>
