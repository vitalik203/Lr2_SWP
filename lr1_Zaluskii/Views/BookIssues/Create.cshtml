@model lr1_Zaluskii.Models.BookIssue

@{
    ViewData["Title"] = "Видати книгу";
}

<h1>Видати книгу читачу</h1>
<hr />

@if (TempData["SessionInfo"] != null)
{
    <div class="alert alert-info">ℹ️ @TempData["SessionInfo"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">⚠️ @TempData["Error"]</div>
}

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="BookId" class="form-label">Книга</label>
                <select asp-for="BookId" class="form-select" asp-items="ViewBag.BookId">
                    <option value="">-- Оберіть книгу --</option>
                </select>
                <span asp-validation-for="BookId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ReaderId" class="form-label">Читач</label>
                <select asp-for="ReaderId" class="form-select" asp-items="ViewBag.ReaderId">
                    <option value="">-- Оберіть читача --</option>
                </select>
                <span asp-validation-for="ReaderId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="IssueDate" class="form-label"></label>
                <input asp-for="IssueDate" class="form-control" type="date" />
                <span asp-validation-for="IssueDate" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DueDate" class="form-label"></label>
                <input asp-for="DueDate" class="form-control" type="date" />
                <span asp-validation-for="DueDate" class="text-danger"></span>
            </div>

            <div class="mb-3 d-flex gap-2">
                <input type="submit" value="Зберегти в сесію" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Скасувати</a>
            </div>
        </form>

        <form asp-action="SaveCreate" method="post">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-success">Записати до бази</button>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
